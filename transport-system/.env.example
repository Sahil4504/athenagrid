# ---- API ----
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ---- Database (Aurora Postgres / local PostGIS) ----
DATABASE_URL=postgresql://athena:athena@localhost:5432/athena_transport?schema=public

# ---- Redis (ElastiCache / local) ----
REDIS_URL=redis://localhost:6379

# ---- Platform commission (12% total: 8% from carrier, 4% fee to shipper) ----
CARRIER_COMMISSION_RATE=0.08
SHIPPER_FEE_RATE=0.04

# Set true on a test/demo deployment to auto-verify new carriers (skip admin approval).
AUTO_VERIFY_CARRIERS=false

# ---- Auth ----
JWT_ACCESS_SECRET=dev_access_change_me
JWT_REFRESH_SECRET=dev_refresh_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ---- Object storage ----
# Leave STORAGE_DRIVER unset for local dev (verification uploads are stubbed, no S3
# needed). Set STORAGE_DRIVER=s3 in prod / when running MinIO to use real signed URLs.
# STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=athena-verification
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
# Set to true to run the web app with in-memory demo data and NO backend.
NEXT_PUBLIC_DEMO=false
